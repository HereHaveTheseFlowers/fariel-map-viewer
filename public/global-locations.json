  "46,12": {
    "name": "Пещеры хаоса",
    "description": "Возможная локация лидера культистов, с которыми гильдия столкнулась в старых руинах западнее Хоммлета.\n\nИнформация об этом локации была найдена Вейдерисом на карте в комнате культиста.\n\nКто знает, что таится в этих пещерах.",
    "terrainType": "mountain",
    "openedInSession": 2,
    "explorationStatus": "unexplored",
    "dangerLevel": "medium"
  },
  "42,9": {
    "name": "Усыпальница ордена Делиан",
    "description": "Небольшая опушка, в центре которой возвышается небольшой холм. В подножии холма можно заметить обветшалую каменную арку, поддерживаемую двумя потрескавшимися колоннами. На арке\nнаписано: \"Сие место есмь последнее земное пристанище великих рыцарей ордена Делиан\".",
    "terrainType": "forest",
    "openedInSession": 4,
    "explorationStatus": "partial",
    "dangerLevel": "low"
  }
}
