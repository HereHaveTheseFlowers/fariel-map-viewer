# Скопируйте: cp .env.example .env
# Переменные с префиксом VITE_ встраиваются в клиент при `npm run dev` / `npm run build`.
#
# Редактирование локаций только в режиме разработки (`npm run dev`).
# Без JSONBin сохранение идёт в public/global-locations.json через dev-сервер.

# Опционально: общий удалённый JSON — тогда чтение/запись через jsonbin.io
# VITE_JSONBIN_BIN_ID=
# VITE_JSONBIN_MASTER_KEY=

# Опционально: свой URL JSON (только чтение), если не JSONBin.
# По умолчанию — /global-locations.json
# VITE_GLOBAL_HEX_JSON_URL=
